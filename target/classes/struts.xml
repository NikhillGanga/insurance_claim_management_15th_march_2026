<!DOCTYPE struts PUBLIC
 "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
 "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <constant name="struts.devMode" value="true"/>
    <constant name="struts.objectFactory" value="spring"/>

    <package name="default" namespace="/" extends="json-default">


        <interceptors>

            <interceptor name="authInterceptor"
                class="com.claim.interceptor.AuthInterceptor"/>

            <interceptor name="roleInterceptor"
                class="com.claim.interceptor.RoleInterceptor"/>

            <interceptor-stack name="authStack">
                <interceptor-ref name="authInterceptor"/>
                <interceptor-ref name="defaultStack"/>
            </interceptor-stack>

        </interceptors>

        <default-interceptor-ref name="authStack"/>



        <global-results>

            <result name="login">/login.jsp</result>

            <result name="unauthorized">
                /unauthorized.jsp
            </result>

        </global-results>



        <action name="login"
                class="com.claim.action.LoginAction"
                method="login">

            <interceptor-ref name="defaultStack"/>

            <result type="json"/>

        </action>


        <action name="logout"
                class="com.claim.action.LoginAction"
                method="logout">

            <result type="json"/>

        </action>




        <action name="saveClaim"
                class="com.claim.action.ClaimAction"
                method="saveClaim">

 <interceptor-ref name="roleInterceptor">
                <param name="allowedRole">CSR</param>
            </interceptor-ref>

            

            <result type="json"/>

        </action>



        <action name="getAllClaims"
                class="com.claim.action.ClaimAction"
                method="listClaims">

<interceptor-ref name="roleInterceptor">
                <param name="allowedRole">CSR</param>
            </interceptor-ref>
            <interceptor-ref name="roleInterceptor">
                <param name="allowedRole">MANAGER</param>
            </interceptor-ref>
            <result type="json"/>

        </action>



        <action name="getClaimById"
                class="com.claim.action.ClaimAction"
                method="editClaim">

            <result type="json"/>

        </action>



        <action name="updateClaim"
                class="com.claim.action.ClaimAction"
                method="updateClaim">

            <result type="json"/>

        </action>



        <action name="deleteClaim"
                class="com.claim.action.ClaimAction"
                method="deleteClaim">

            <result type="json"/>

        </action>



        <action name="submitClaim"
                class="com.claim.action.ClaimAction"
                method="submitClaim">

            <interceptor-ref name="roleInterceptor">
                <param name="allowedRole">CSR</param>
            </interceptor-ref>

            <result type="json"/>

        </action>



        <action name="approveClaim"
                class="com.claim.action.ClaimAction"
                method="approveClaim">

            <interceptor-ref name="roleInterceptor">
                <param name="allowedRole">MANAGER</param>
            </interceptor-ref>

            <result type="json"/>

        </action>

    </package>

</struts>